# Sally environment variables (optional - keys can also be set in the app UI)

# AI Provider key — set ONE of these depending on your provider
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Sally Vision Backend (Cloud Run)
GEMINI_BACKEND_URL=https://sally-backend-xxx.run.app

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=...

# Speech-to-Text: When using the Gemini provider, your Gemini API key handles
# transcription automatically (via Gemini 2.0 Flash). No separate STT key needed.
# For Anthropic/OpenAI providers, set an OpenAI key for Whisper fallback:
# WHISPER_API_KEY=sk-...
