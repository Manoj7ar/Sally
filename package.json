{
  "name": "sally",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Use any website with just your voice - voice-first accessibility agent for motor impairments and RSI",
  "main": "dist-electron/electron/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "npm run build:electron && concurrently -k \"vite\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:electron": "tsc -p electron/tsconfig.json && tsc -p electron/preload/tsconfig.json && node -e \"require('fs').mkdirSync('dist-electron/electron/preload',{recursive:true});require('fs').writeFileSync('dist-electron/electron/preload/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "build": "npm run build:electron && vite build",
    "preview": "npm run build && electron .",
    "lint": "eslint src electron shared scripts tests vite.config.ts vitest.config.ts eslint.config.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "npm run build:electron && tsc -b",
    "verify:desktop": "tsx scripts/desktop-doctor.ts",
    "build:check": "npm run build:electron",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run verify:desktop && npm run build && node --check sally-backend/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "electron-store": "^10.0.0",
    "uiohook-napi": "^1.5.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.sally.app",
    "productName": "Sally",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "entitlements": "config/macos/entitlements.mac.plist",
      "entitlementsInherit": "config/macos/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
